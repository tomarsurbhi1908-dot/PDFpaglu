{
  "name": "pdf-tools-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "preview": "npm run build && opennextjs-cloudflare preview",
    "deploy": "npm run build && opennextjs-cloudflare deploy",
    "upload": "npm run build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.19.11",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "next": "15.5.19",
    "pdf-lib": "^1.17.1",
    "postcss": "^8.4.39",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.4.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3"
  },
  "devDependencies": {
    "wrangler": "4.103.0"
  }
}
